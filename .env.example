# App connection — non-superuser role, subject to row-level security
DATABASE_URL=postgres://movie_app:movie_app@localhost:5432/movie
# Admin connection — used by drizzle-kit for migrations (table owner)
DATABASE_URL_ADMIN=postgres://localhost:5432/movie
BETTER_AUTH_SECRET=change-me
BETTER_AUTH_URL=http://localhost:3000
# Firecrawl — enables wishlist retailer URL scraping
FIRECRAWL_API_KEY=
# TMDB (v3 key or v4 read token) — enables cast data + Top actors stat
TMDB_API_KEY=
# Hosts allowed to reach the server when hosting publicly:
# a comma-separated list (spine.example.com) or "*" for any host.
# When hosting, also set BETTER_AUTH_URL to the public URL.
ALLOWED_HOSTS=
